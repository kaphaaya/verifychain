# ─── Blockchain ────────────────────────────────────────
ARBITRUM_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS
ADMIN_PRIVATE_KEY=0xYOUR_DEPLOYER_WALLET_PRIVATE_KEY

# ─── Storage ────────────────────────────────────────────
WEB3_STORAGE_TOKEN=your_web3_storage_token_here

# ─── Auth ───────────────────────────────────────────────
ADMIN_SECRET=change-this-to-a-strong-secret

# ─── Database ───────────────────────────────────────────
# SQLite (default for hackathon — fast to set up)
DATABASE_URL=sqlite+aiosqlite:///./verifychain.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/verifychain
