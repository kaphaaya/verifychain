"use client";
import { useState, useEffect } from "react";
import axios from "axios";
import toast from "react-hot-toast";
import Link from "next/link";

const API = process.env.NEXT_PUBLIC_API_URL || "http://localhost:8000";
const SECRET = process.env.NEXT_PUBLIC_ADMIN_SECRET || "verifychain-admin-secret-change-me";
const H = { "x-admin-secret": SECRET };

function Nav() {
  return (
    <nav className="nav">
      <Link href="/" className="nav-logo">
        <div className="logo-mark">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M7 1L12.5 4V10L7 13L1.5 10V4L7 1Z" stroke="white" strokeWidth="1.5" fill="none"/>
            <circle cx="7" cy="7" r="2.2" fill="white"/>
          </svg>
        </div>
        Verify<span style={{color:"var(--accent)"}}>Chain</span>
      </Link>
      <div style={{display:"flex",alignItems:"center",gap:8,padding:"4px 12px",borderRadius:8,background:"rgba(167,139,250,0.08)",border:"1px solid rgba(167,139,250,0.2)"}}>
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M6 1L10.5 3.5V8.5L6 11L1.5 8.5V3.5L6 1Z" stroke="var(--purple)" strokeWidth="1" fill="none"/><circle cx="6" cy="6" r="1.5" fill="var(--purple)"/></svg>
        <span style={{fontSize:11,fontFamily:"DM Mono,monospace",color:"var(--purple)",letterSpacing:"0.05em"}}>ADMIN</span>
      </div>
    </nav>
  );
}

function StatCard({icon,label,value,color="var(--accent)",sub}:{icon:any,label:string,value:any,color?:string,sub?:string}) {
  return (
    <div className="card" style={{display:"flex",flexDirection:"column",gap:4}}>
      <div style={{marginBottom:12,opacity:0.7}}>{icon}</div>
      <div style={{fontSize:32,fontWeight:800,letterSpacing:"-0.04em",color}}>{value??"-"}</div>
      <div style={{fontSize:12,color:"var(--muted)",fontFamily:"DM Mono,monospace",letterSpacing:"0.04em"}}>{label.toUpperCase()}</div>
      {sub && <div style={{fontSize:11,color:"var(--muted)",marginTop:2}}>{sub}</div>}
    </div>
  );
}

function AppCard({app,onApprove,onReject}:{app:any,onApprove:(id:number,tier:number)=>void,onReject:(id:number)=>void}) {
  const [loading,setLoading] = useState(false);
  const tierLabels = ["","Basic","Standard","Premium"];
  const tierColors = ["","var(--muted2)","var(--accent)","var(--purple)"];

  return (
    <div style={{
      border:"1px solid var(--border)",borderRadius:18,overflow:"hidden",
      background:"var(--surface)",transition:"border-color 0.2s",
    }}
      onMouseEnter={e=>(e.currentTarget as HTMLElement).style.borderColor="var(--border2)"}
      onMouseLeave={e=>(e.currentTarget as HTMLElement).style.borderColor="var(--border)"}
    >
      <div style={{padding:"20px 22px",display:"flex",gap:16,alignItems:"flex-start",justifyContent:"space-between",flexWrap:"wrap" as const}}>
        <div style={{flex:1,minWidth:0}}>
          <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:6,flexWrap:"wrap" as const}}>
            <span style={{fontWeight:700,fontSize:16}}>{app.companyName}</span>
            <span style={{
              fontSize:10,fontFamily:"DM Mono,monospace",padding:"2px 8px",borderRadius:99,
              background:`rgba(${app.tier===3?"167,139,250":app.tier===2?"0,212,255":"160,180,220"},0.1)`,
              color:tierColors[app.tier]||"var(--muted2)",
              border:`1px solid rgba(${app.tier===3?"167,139,250":app.tier===2?"0,212,255":"160,180,220"},0.2)`,
            }}>
              {tierLabels[app.tier]||"Unknown"}
            </span>
          </div>
          <div style={{fontFamily:"DM Mono,monospace",fontSize:11,color:"var(--muted)",marginBottom:10,wordBreak:"break-all" as const}}>{app.wallet}</div>
          <div style={{display:"flex",gap:16,fontSize:12,color:"var(--muted2)",flexWrap:"wrap" as const}}>
            <span style={{display:"flex",alignItems:"center",gap:4}}>
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><circle cx="6" cy="4.5" r="2.5" stroke="currentColor" strokeWidth="1.1"/><path d="M1.5 10.5C1.5 8.57 3.57 7 6 7C8.43 7 10.5 8.57 10.5 10.5" stroke="currentColor" strokeWidth="1.1" strokeLinecap="round"/></svg>
              {app.country||"—"}
            </span>
            <span style={{display:"flex",alignItems:"center",gap:4}}>
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><rect x="1" y="2" width="10" height="8" rx="1.5" stroke="currentColor" strokeWidth="1.1"/><path d="M1 5H11" stroke="currentColor" strokeWidth="1.1"/></svg>
              {app.taxId||"—"}
            </span>
            <span style={{display:"flex",alignItems:"center",gap:4}}>
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><circle cx="6" cy="6" r="4.5" stroke="currentColor" strokeWidth="1.1"/><path d="M6 3V6L8 8" stroke="currentColor" strokeWidth="1.1" strokeLinecap="round"/></svg>
              {app.submittedAt ? new Date(app.submittedAt).toLocaleDateString() : "—"}
            </span>
          </div>
        </div>
        <div style={{display:"flex",gap:8,flexShrink:0,flexWrap:"wrap" as const}}>
          {app.docsIPFS && (
            <a href={`https://ipfs.io/ipfs/${app.docsIPFS}`} target="_blank" rel="noreferrer"
              className="btn btn-ghost" style={{fontSize:12,padding:"8px 14px"}}>
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 8L6 4L10 8M6 4V10" stroke="currentColor" strokeWidth="1.3" strokeLinecap="round" strokeLinejoin="round"/></svg>
              Docs
            </a>
          )}
          <button
            onClick={async()=>{setLoading(true);await onReject(app.id);setLoading(false);}}
            disabled={loading} className="btn btn-danger" style={{fontSize:12,padding:"8px 14px"}}>
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 2L10 10M10 2L2 10" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round"/></svg>
            Reject
          </button>
          <button
            onClick={async()=>{setLoading(true);await onApprove(app.id,app.tier||2);setLoading(false);}}
            disabled={loading} className="btn btn-success" style={{fontSize:12,padding:"8px 14px"}}>
            {loading
              ? <span className="spinner" style={{borderColor:"rgba(0,229,160,0.2)",borderTopColor:"var(--green)"}}/>
              : <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6L5 9L10 3" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"/></svg>
            }
            Approve & mint
          </button>
        </div>
      </div>
    </div>
  );
}

export default function AdminPage() {
  const [tab, setTab] = useState<"queue"|"all"|"analytics">("queue");
  const [queue, setQueue] = useState<any[]>([]);
  const [suppliers, setSuppliers] = useState<any[]>([]);
  const [stats, setStats] = useState<any>(null);
  const [loading, setLoading] = useState(true);

  const load = async () => {
    setLoading(true);
    try {
      const [q,s,st] = await Promise.all([
        axios.get(`${API}/api/admin/queue`,{headers:H}),
        axios.get(`${API}/api/admin/suppliers`,{headers:H}),
        axios.get(`${API}/api/admin/stats`,{headers:H}),
      ]);
      setQueue(q.data||[]); setSuppliers(s.data||[]); setStats(st.data);
    } catch { toast.error("Failed to load dashboard"); }
    finally { setLoading(false); }
  };

  useEffect(()=>{load();},[]);

  const approve = async (id:number,tier:number) => {
    try {
      await axios.post(`${API}/api/admin/approve/${id}`,{tier},{headers:H});
      toast.success("Credential minted on Arbitrum!");
      load();
    } catch(e:any) { toast.error(e?.response?.data?.detail||"Approval failed"); }
  };

  const reject = async (id:number) => {
    try {
      await axios.post(`${API}/api/admin/reject/${id}`,{},{headers:H});
      toast.success("Application rejected");
      load();
    } catch(e:any) { toast.error(e?.response?.data?.detail||"Rejection failed"); }
  };

  const tabs = [
    {k:"queue",     l:`Review queue ${queue.length>0?`(${queue.length})`:""}`},
    {k:"all",       l:"All suppliers"},
    {k:"analytics", l:"Analytics"},
  ];

  const statusColors:Record<string,string> = {
    pending:"var(--amber)", approved:"var(--green)", rejected:"var(--red)", revoked:"var(--muted)",
  };

  return (
    <div style={{minHeight:"100vh",background:"var(--bg)"}}>
      <Nav/>
      <div style={{maxWidth:960,margin:"0 auto",padding:"40px 24px 80px"}}>

        {/* Header */}
        <div className="animate-in" style={{marginBottom:32}}>
          <div className="eyebrow" style={{marginBottom:10}}>Admin Dashboard</div>
          <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",flexWrap:"wrap" as const,gap:12}}>
            <h1 style={{fontSize:30,fontWeight:800,letterSpacing:"-0.035em"}}>Supplier registry</h1>
            <button onClick={load} className="btn btn-ghost" style={{fontSize:13}}>
              <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M11.5 6.5C11.5 9.26 9.26 11.5 6.5 11.5C3.74 11.5 1.5 9.26 1.5 6.5C1.5 3.74 3.74 1.5 6.5 1.5C8.04 1.5 9.42 2.17 10.37 3.23M10.37 3.23V1.5M10.37 3.23H8.67" stroke="currentColor" strokeWidth="1.3" strokeLinecap="round" strokeLinejoin="round"/></svg>
              Refresh
            </button>
          </div>
        </div>

        {/* Stat cards */}
        <div className="animate-in-1" style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:14,marginBottom:28}}>
          <StatCard icon={<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 2L16 5.5V12.5L9 16L2 12.5V5.5L9 2Z" stroke="var(--accent)" strokeWidth="1.3" fill="none"/></svg>} label="Total suppliers" value={stats?.totalSuppliers??0} color="var(--accent)"/>
          <StatCard icon={<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="7" stroke="var(--amber)" strokeWidth="1.3"/><path d="M9 5V9L11.5 11.5" stroke="var(--amber)" strokeWidth="1.3" strokeLinecap="round"/></svg>} label="Pending review" value={queue.length} color="var(--amber)"/>
          <StatCard icon={<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M3 9L7.5 13.5L15 5" stroke="var(--green)" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"/></svg>} label="Approved" value={stats?.approvedSuppliers??0} color="var(--green)"/>
          <StatCard icon={<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 2L16 5.5V12.5L9 16L2 12.5V5.5L9 2Z" stroke="var(--purple)" strokeWidth="1.3" fill="none"/><circle cx="9" cy="9" r="2.5" fill="var(--purple)"/></svg>} label="NFTs minted" value={stats?.totalNFTs??stats?.approvedSuppliers??0} color="var(--purple)"/>
        </div>

        {/* Tabs */}
        <div className="animate-in-2" style={{display:"flex",gap:4,marginBottom:20,background:"var(--surface2)",padding:4,borderRadius:12,width:"fit-content"}}>
          {tabs.map(t=>(
            <button key={t.k} onClick={()=>setTab(t.k as any)}
              style={{
                padding:"7px 16px",borderRadius:9,fontSize:13,fontWeight:600,
                background:tab===t.k?"var(--surface)":"transparent",
                color:tab===t.k?"var(--text)":"var(--muted)",
                border:tab===t.k?"1px solid var(--border)":"1px solid transparent",
                cursor:"pointer",fontFamily:"Syne,sans-serif",transition:"all 0.15s",
                whiteSpace:"nowrap" as const,
              }}>
              {t.l}
            </button>
          ))}
        </div>

        {/* Queue tab */}
        {tab==="queue" && (
          <div className="animate-in-3" style={{display:"flex",flexDirection:"column",gap:12}}>
            {loading ? (
              <div className="card" style={{textAlign:"center",padding:"48px"}}>
                <div className="spinner" style={{width:28,height:28,margin:"0 auto 14px",borderWidth:3}}/>
                <div style={{color:"var(--muted2)",fontSize:14}}>Loading queue...</div>
              </div>
            ) : queue.length===0 ? (
              <div className="card" style={{textAlign:"center",padding:"52px"}}>
                <div style={{
                  width:52,height:52,borderRadius:16,margin:"0 auto 16px",
                  display:"flex",alignItems:"center",justifyContent:"center",
                  background:"rgba(0,229,160,0.08)",border:"1px solid rgba(0,229,160,0.2)",
                }}>
                  <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M4 11L9 16L18 7" stroke="var(--green)" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"/></svg>
                </div>
                <div style={{fontWeight:700,fontSize:17,marginBottom:6}}>Queue is clear</div>
                <div style={{color:"var(--muted)",fontSize:13}}>All applications have been reviewed</div>
              </div>
            ) : queue.map(app=>(
              <AppCard key={app.id} app={app} onApprove={approve} onReject={reject}/>
            ))}
          </div>
        )}

        {/* All suppliers tab */}
        {tab==="all" && (
          <div className="animate-in-3" style={{
            background:"var(--surface)",border:"1px solid var(--border)",
            borderRadius:18,overflow:"hidden",
          }}>
            {/* Table header */}
            <div style={{
              display:"grid",gridTemplateColumns:"2fr 1.2fr 1fr 0.8fr 0.8fr",
              padding:"12px 22px",background:"var(--surface2)",
              borderBottom:"1px solid var(--border)",
            }}>
              {["Company","Wallet","Country","Tier","Status"].map(h=>(
                <div key={h} style={{fontSize:10,color:"var(--muted)",fontFamily:"DM Mono,monospace",letterSpacing:"0.06em"}}>{h.toUpperCase()}</div>
              ))}
            </div>
            {loading ? (
              <div style={{textAlign:"center",padding:40}}><div className="spinner" style={{margin:"0 auto",width:24,height:24}}/></div>
            ) : suppliers.length===0 ? (
              <div style={{textAlign:"center",padding:"40px",color:"var(--muted)",fontSize:14}}>No suppliers yet</div>
            ) : suppliers.map((s,i)=>(
              <div key={s.id} style={{
                display:"grid",gridTemplateColumns:"2fr 1.2fr 1fr 0.8fr 0.8fr",
                padding:"14px 22px",alignItems:"center",
                borderBottom:i<suppliers.length-1?"1px solid var(--border)":"none",
                transition:"background 0.15s",
              }}
                onMouseEnter={e=>(e.currentTarget as HTMLElement).style.background="rgba(255,255,255,0.015)"}
                onMouseLeave={e=>(e.currentTarget as HTMLElement).style.background="transparent"}
              >
                <div style={{fontWeight:600,fontSize:14}}>{s.companyName}</div>
                <div style={{fontFamily:"DM Mono,monospace",fontSize:11,color:"var(--muted)",overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap" as const}}>
                  {s.wallet?.slice(0,6)}...{s.wallet?.slice(-4)}
                </div>
                <div style={{fontSize:13,color:"var(--muted2)"}}>{s.country||"—"}</div>
                <div style={{fontSize:12,fontFamily:"DM Mono,monospace",
                  color:s.tier===3?"var(--purple)":s.tier===2?"var(--accent)":"var(--muted2)"}}>
                  T{s.tier}
                </div>
                <div>
                  <span className={`badge badge-${s.status}`}>{s.status?.toUpperCase()}</span>
                </div>
              </div>
            ))}
          </div>
        )}

        {/* Analytics tab */}
        {tab==="analytics" && (
          <div className="animate-in-3" style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:16}}>
            {[
              {l:"Total verifications today",   v:stats?.queriesToday??0,     c:"var(--accent)"},
              {l:"Revenue this month (USDC)",    v:`$${stats?.revenueMonth??0}`,c:"var(--green)"},
              {l:"Avg. review time",             v:stats?.avgReviewTime??"<2h",c:"var(--amber)"},
              {l:"Countries represented",        v:stats?.countries??0,        c:"var(--purple)"},
            ].map(s=>(
              <div key={s.l} className="card" style={{padding:"24px"}}>
                <div style={{fontSize:28,fontWeight:800,letterSpacing:"-0.04em",color:s.c,marginBottom:6}}>{s.v}</div>
                <div style={{fontSize:12,color:"var(--muted)",fontFamily:"DM Mono,monospace",letterSpacing:"0.04em"}}>{s.l.toUpperCase()}</div>
              </div>
            ))}
            <div className="card" style={{gridColumn:"span 2",padding:"24px"}}>
              <div style={{fontSize:13,color:"var(--muted)",fontFamily:"DM Mono,monospace",marginBottom:16,letterSpacing:"0.05em"}}>CONTRACT INFO</div>
              <div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:12}}>
                {[
                  {l:"Network",  v:"Arbitrum Sepolia"},
                  {l:"Contract", v:`${process.env.NEXT_PUBLIC_CONTRACT_ADDRESS?.slice(0,8)}...${process.env.NEXT_PUBLIC_CONTRACT_ADDRESS?.slice(-6)}`},
                  {l:"Standard", v:"ERC-721 Soul-bound"},
                ].map(({l,v})=>(
                  <div key={l} className="card-sm">
                    <div style={{fontSize:10,color:"var(--muted)",fontFamily:"DM Mono,monospace",marginBottom:4}}>{l.toUpperCase()}</div>
                    <div style={{fontSize:13,fontFamily:"DM Mono,monospace",color:"var(--accent)"}}>{v||"—"}</div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        )}
      </div>
    </div>
  );
}
